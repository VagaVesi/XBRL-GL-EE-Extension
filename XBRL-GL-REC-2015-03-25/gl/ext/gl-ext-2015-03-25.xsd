<schema targetNamespace="http://www.xbrl.org/int/gl/ext/2015-03-25"
  elementFormDefault="qualified" attributeFormDefault="unqualified"
  xmlns="http://www.w3.org/2001/XMLSchema"
  xmlns:xbrll="http://www.xbrl.org/2003/linkbase"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xbrli="http://www.xbrl.org/2003/instance"
  xmlns:gl-cor="http://www.xbrl.org/int/gl/cor/2015-03-25"
  xmlns:gl-ext="http://www.xbrl.org/int/gl/ext/2015-03-25"
  xmlns:gl-gen="http://www.xbrl.org/int/gl/gen/2015-03-25">
  <annotation>
    <appinfo>
      <xbrll:linkbaseRef xlink:type="simple" xlink:arcrole="http://www.w3.org/1999/xlink/properties/linkbase"
        xlink:href="gl-ext-2015-03-25-presentation.xml" xlink:title="Presentation Links, all"
        xlink:role="http://www.xbrl.org/2003/role/presentationLinkbaseRef"/>
    </appinfo>
  </annotation>
  <import namespace="http://www.xbrl.org/2003/instance" schemaLocation="http://www.xbrl.org/2003/xbrl-instance-2003-12-31.xsd"/>
  <import namespace="http://www.xbrl.org/int/gl/gen/2015-03-25" schemaLocation="../gen/gl-gen-2015-03-25.xsd"/>  
  
  <!-- EXTENSION for identifiers-->
  <element name="identifierCodeType" id="gl-ext_identifierCodeType" type="gl-ext:identifierCodeTypeItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>
  <element name="additionalCategory" id="gl-ext_additionalCategory" type="gl-ext:additionalCategoryItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>
  <element name="transactionPartyType" id="gl-ext_transactionPartyType" type="gl-ext:transactionPartyTypeItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>

  <!-- EXTENSION for multiple data sources-->
  <element name="sourceId" id="gl-ext_sourceId" type="gl-ext:sourceIdItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>

  <!--EXTENSION for dataset version-->
  <element name="version" id="gl-ext_version" type="gl-ext:versionItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>
   
  <!--EXTENSION is dataset approved-->
  <element name="isApproved" id="gl-ext_isApproved" type="gl-ext:isApprovedItemType" substitutionGroup="xbrli:item" nillable="true" xbrli:periodType="instant"/>
 
</schema>
