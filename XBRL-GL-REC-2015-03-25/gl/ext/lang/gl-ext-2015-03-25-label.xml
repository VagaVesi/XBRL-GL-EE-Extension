<linkbase
  xsi:schemaLocation="http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd"
  xmlns="http://www.xbrl.org/2003/linkbase"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xlink="http://www.w3.org/1999/xlink">
  <labelLink xlink:type="extended" xlink:role="http://www.xbrl.org/2003/role/link">
    <!-- Identifier code type-->
    <loc xlink:type="locator" xlink:href="../gl-ext-2015-03-25.xsd#gl-ext_identifierCodeType" xlink:label="identifierCodeType"/>
    <label xlink:type="resource" xlink:label="identifierCodeType_lbl" xlink:role="http://www.xbrl.org/2003/role/documentation" xml:lang="en">Specifies identifier code type. Helps validate different identifier codes.</label>
    <label xlink:type="resource" xlink:label="identifierCodeType_lbl" xlink:role="http://www.xbrl.org/2003/role/label" xlink:title="gl-ext_identifierCodeType_en" xml:lang="en">Identifier Code Type</label>
    <labelArc xlink:type="arc" xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label" xlink:from="identifierCodeType" xlink:to="identifierCodeType_lbl"/>
    <!-- Transaction Party type-->
    <loc xlink:type="locator" xlink:href="../gl-ext-2015-03-25.xsd#gl-ext_transactionPartyType" xlink:label="transactionPartyType"/>
    <label xlink:type="resource" xlink:label="transactionPartyType_lbl" xlink:role="http://www.xbrl.org/2003/role/documentation" xml:lang="en">Specifies identifier reference identifier code type. Helps validate different identifier codes.</label>
    <label xlink:type="resource" xlink:label="transactionPartyType_lbl" xlink:role="http://www.xbrl.org/2003/role/label" xlink:title="gl-ext_transactionPartyType_en" xml:lang="en">Total Type</label>
    <labelArc xlink:type="arc" xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label" xlink:from="transactionPartyType" xlink:to="transactionPartyType_lbl"/>
    <!-- EXTENSION for multiple data sources-->
    <loc xlink:type="locator" xlink:href="../gl-ext-2015-03-25.xsd#gl-ext_sourceId" xlink:label="sourceId"/>
    <label xlink:type="resource" xlink:label="sourceId_lbl" xlink:role="http://www.xbrl.org/2003/role/documentation" xml:lang="en">Identification for data source. Primary source should have value 1. Used in the case of multiple data sources.</label>
    <label xlink:type="resource" xlink:label="sourceId_lbl" xlink:role="http://www.xbrl.org/2003/role/label" xlink:title="gl-ext_sourceId" xml:lang="en">Source Identification</label>
    <labelArc xlink:type="arc" xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label" xlink:from="sourceId" xlink:to="sourceId_lbl"/>

    <loc xlink:type="locator" xlink:href="../gl-ext-2015-03-25.xsd#gl-ext_sourcesCount" xlink:label="sourcesCount"/>
    <label xlink:type="resource" xlink:label="sourcesCount_lbl" xlink:role="http://www.xbrl.org/2003/role/documentation" xml:lang="en">Total count of data sources. Used in the case of multiple data sources.</label>
    <label xlink:type="resource" xlink:label="sourcesCount_lbl" xlink:role="http://www.xbrl.org/2003/role/label" xlink:title="gl-ext_sourcesCount" xml:lang="en">Sources Count</label>
    <labelArc xlink:type="arc" xlink:arcrole="http://www.xbrl.org/2003/arcrole/concept-label" xlink:from="sourcesCount" xlink:to="sourcesCount_lbl"/>
 


  </labelLink>
</linkbase>
